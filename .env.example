# ============================================================
# StickerRadar — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Telegram credentials ---
# Get TG_API_ID and TG_API_HASH from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram numeric user ID (get it from @userinfobot or @getidsbot)
OWNER_USER_ID=

# --- Local paths (defaults work fine, change only if needed) ---
DATA_DIR=./data
SESSION_PATH=./data/sessions/user
DB_PATH=./data/app.sqlite

# --- Embedding model ---
# Default: fast multilingual CLIP (2021, 512-dim, ~380 MB download)
MODEL_NAME=sentence-transformers/clip-ViT-B-32-multilingual-v1

# Better quality (2024, 89 languages incl. Russian & Chinese, ~3.5 GB):
# MODEL_NAME=jinaai/jina-clip-v2
# (also run: uv add 'transformers>=4.36' einops)

# Custom dual-model setup: separate image encoder (leave empty to use MODEL_NAME)
IMAGE_MODEL_NAME=

# Run `python -m app models` for the full list and install instructions.

# --- Runtime tuning ---
TOP_K=10
FRAME_COUNT=5
SCAN_CONCURRENCY=4
BOT_SEND_DELAY_MS=250

# --- Optional features (leave as-is for MVP) ---
ENABLE_CAPTIONS=false
CAPTION_PROVIDER=none
