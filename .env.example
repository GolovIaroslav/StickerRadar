# StickerRadar configuration.
# Copy this file to ".env" and fill in the values below.
# Never commit .env to git (it contains your private keys).
# New users can also run:  python -m app setup


# TELEGRAM CREDENTIALS (required)

# Your Telegram API app keys.
# Get them at https://my.telegram.org/apps — log in with your phone number,
# create an app (any name), then copy the two values it shows.
TG_API_ID=
TG_API_HASH=

# Bot token. Open @BotFather in Telegram, send /newbot, follow the steps,
# and paste the token it gives you (looks like 123456:ABC-DEF...).
BOT_TOKEN=

# Your personal numeric Telegram user ID. The bot will ONLY answer you.
# Get it from @userinfobot or @getidsbot (just send them any message).
OWNER_USER_ID=


# EMBEDDING MODEL (the brain of the search)

# Change ONLY the "MODEL_NAME=" line below. Paste a name from this list and the
# model downloads automatically on the next `sync`. Leave IMAGE_MODEL_NAME empty.
# After changing the model, run:  uv run python -m app sync --reindex
#
#  MODEL_NAME value                                PARAMS   SIZE       LICENSE        NOTES
#  google/siglip2-large-patch16-256                0.9B     ~3.53 GB   Apache-2.0     109 langs incl. RU/ZH  (DEFAULT — best balance quality/size)
#  google/siglip2-base-patch16-224                 0.4B     ~1.5 GB    Apache-2.0     109 langs; lightweight verified fallback
#  google/siglip2-so400m-patch16-384               ~1.1B    ~2 GB      Apache-2.0     109 langs; higher quality, heavier
#  Qwen/Qwen3-VL-Embedding-2B                      2B       ~4.26 GB   Apache-2.0     best quality; 30+ langs, multimodal
#                                                                                    needs: uv add 'transformers>=4.57' accelerate qwen-vl-utils
#  jinaai/jina-clip-v2                             0.9B     ~1.73 GB   CC-BY-NC-4.0   89 langs, multimodal; needs: uv add einops
#  jinaai/jina-embeddings-v5-omni-nano-retrieval   ~0.95B   ~1.9 GB    CC-BY-NC-4.0   2026 multimodal (experimental)
#  jinaai/jina-embeddings-v5-omni-small-retrieval  ~1.56B   ~3.12 GB   CC-BY-NC-4.0   2026 multimodal (experimental)
#  facebook/metaclip-2-worldwide-huge              ~2B      ~4+ GB     CC-BY-NC-4.0   300+ langs, SOTA multilingual (experimental)
#  visheratin/mexma-siglip2                        ~1B      ~2 GB      MIT            80 langs, strong RU; needs ALLOW_REMOTE_CODE=1 (experimental)
#  openai/clip-vit-large-patch14                   0.4B     ~1.71 GB   MIT            English only (no Russian support)
#  apple/MobileCLIP2-S2                            ~99M     ~398 MB    Apple-AMLR     research-only; needs: uv add open_clip_torch
#  jinaai/jina-embeddings-v4                       4B       ~7.89 GB   Qwen-Research  legacy/heavy, GPU recommended
#
# Run `uv run python -m app models` for the same list with full install notes.
#
# If the default fails to load, switch to the load-tested lightweight fallback:
#   MODEL_NAME=google/siglip2-base-patch16-224
#
# Text-only models (Gemini Embedding, OpenAI text-embedding, BGE, E5) do NOT
# work here — they cannot encode sticker images.

MODEL_NAME=google/siglip2-large-patch16-256

# MODEL_NAME also accepts a LOCAL FOLDER PATH (not only a Hugging Face id),
# e.g.  MODEL_NAME=/home/me/models/my-clip   (or  C:\models\my-clip  on Windows).
# It must be a CLIP-style model that embeds BOTH images and text.

# Advanced only: separate image encoder for a custom dual-model setup.
# Leave EMPTY unless you know you need it.
IMAGE_MODEL_NAME=

# Where to run the model: auto | cpu | cuda
#   auto = GPU if available (large models load in fp16), else CPU.
#          Falls back to CPU automatically if the GPU runs out of memory.
# The 2B default needs ~4 GB VRAM in fp16. On a smaller/busy GPU use DEVICE=cpu
# (uses system RAM, slower but reliable).
DEVICE=auto


# SEARCH & SYNC TUNING (defaults are fine)

# MODEL MEMORY MANAGEMENT
# How many idle seconds to wait before unloading the model from RAM/VRAM.
# The model is loaded only when a search or /sync arrives, then unloaded after
# this many seconds of inactivity — so the bot process stays light at rest.
# Set to 0 to keep the model loaded forever (lower latency for frequent queries).
MODEL_IDLE_UNLOAD_SEC=180


# How many stickers the bot returns per query.
TOP_K=10

# How many frames to sample from animated stickers / GIFs for embedding.
# More frames = slightly better matching but slower indexing and more disk.
FRAME_COUNT=5

# How many files to download from Telegram in parallel. Higher = faster,
# but too high may trigger Telegram rate limits. 4 is a safe value.
SCAN_CONCURRENCY=4

# Delay (milliseconds) between stickers when the bot sends results,
# to avoid hitting Telegram's send limits.
BOT_SEND_DELAY_MS=250


# LOCAL PATHS (leave as-is unless you want a custom location)

DATA_DIR=./data
SESSION_PATH=./data/sessions/user
DB_PATH=./data/app.sqlite


# OPTIONAL / EXPERIMENTAL (leave off)

ENABLE_CAPTIONS=false
CAPTION_PROVIDER=none

# OCR: extract text from sticker/GIF frames for hybrid text+vector search.
# Enables finding stickers by exact words printed on them (memes, labels, profanity, etc.).
OCR_ENABLED=true

# OCR backend: easyocr (default) | rapidocr | glm-ocr
#   easyocr    — 80+ languages, scene text specialist. Install: uv add easyocr
#                Downloads models (~300 MB) on first sync.
#                In local StickerRadar tests: ~549 ms/image, better Russian quality.
#   rapidocr   — PaddleOCR quality via ONNX, no GPU needed, faster CPU inference.
#                Install: uv add rapidocr-onnxruntime
#                In local StickerRadar tests: ~409 ms/image, but lower Russian accuracy.
#   glm-ocr    — llama.cpp OCR-LLM path. Install llama.cpp (`llama-cli`) and keep
#                this as a fallback for hard images, not the primary bulk OCR engine.
#                Local StickerRadar test after WEBP→PNG conversion: ~5.27 s/image.
# If the backend is not installed the OCR step is silently skipped.
OCR_BACKEND=easyocr

# Languages for EasyOCR (comma-separated language codes).
# "ru,en" loads the Cyrillic + Latin recognizer — already covers Russian, Ukrainian,
# English, German, French, Spanish and 40+ other Latin-script languages.
# Add more scripts as needed (each new script downloads its own model ~50–200 MB):
#   ko = Korean   ja = Japanese   ch_sim = Chinese Simplified
#   ar = Arabic   hi = Hindi      th = Thai
# Full list: https://www.jaided.ai/easyocr/
# Note: OCR_LANGS has no effect when OCR_BACKEND=rapidocr.
OCR_LANGS=ru,en

# Run OCR on GPU (false = CPU). CPU is recommended — avoids GPU contention with
# the embedding model. EasyOCR finishes in <100 ms/frame on CPU for sticker images.
# OCR_USE_GPU=false

# Optional second-pass OCR for hard cases. When enabled, StickerRadar re-runs only
# low-confidence / too-short OCR results through OCR_FALLBACK_BACKEND.
# Keep this OFF by default: GLM rescue OCR is much slower than EasyOCR/RapidOCR.
OCR_FALLBACK_ENABLED=false
OCR_FALLBACK_BACKEND=glm-ocr
OCR_FALLBACK_CONFIDENCE=0.45
OCR_FALLBACK_MIN_CHARS=3

# GGUF repo for OCR_FALLBACK_BACKEND=glm-ocr.
OCR_LLM_REPO=ggml-org/GLM-OCR-GGUF:Q8_0

# Security: allow execution of remote model code from HuggingFace.
# Only needed when using a CUSTOM model not in the built-in registry.
# Registry models that require remote code (jina-clip-v2, visheratin/mexma-siglip2,
# etc.) are pre-approved but still print a warning on load.
# Setting this to 1 for a custom model executes arbitrary Python
# code from the model repo — only enable if you trust the source.
# ALLOW_REMOTE_CODE=0
