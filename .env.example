# ============================================================
# StickerRadar — configuration
# Copy this file to ".env" and fill in the values below.
# NEVER commit .env to git (it contains your private keys).
# ============================================================


# ------------------------------------------------------------
# TELEGRAM CREDENTIALS (required)
# ------------------------------------------------------------

# Your Telegram API app keys.
# Get them at https://my.telegram.org/apps — log in with your phone number,
# create an app (any name), then copy the two values it shows.
TG_API_ID=
TG_API_HASH=

# Bot token. Open @BotFather in Telegram, send /newbot, follow the steps,
# and paste the token it gives you (looks like 123456:ABC-DEF...).
BOT_TOKEN=

# Your personal numeric Telegram user ID. The bot will ONLY answer you.
# Get it from @userinfobot or @getidsbot (just send them any message).
OWNER_USER_ID=


# ------------------------------------------------------------
# EMBEDDING MODEL (this is the brain of the search)
# ------------------------------------------------------------
#
# Change ONLY the "MODEL_NAME=" line below. Paste a name from this list and
# the model downloads automatically on the next `sync`. Leave IMAGE_MODEL_NAME
# empty. After changing the model, run:  python -m app sync --reindex
#
#  MODEL_NAME value                                PARAMS  SIZE      LICENSE        NOTES
#  ----------------------------------------------------------------------------------------------------
#  Qwen/Qwen3-VL-Embedding-2B                      2B      ~4.26 GB  Apache-2.0     30+ langs, multimodal  <- DEFAULT
#                                                                                  needs: uv add 'transformers>=4.57' accelerate qwen-vl-utils
#  google/siglip2-base-patch16-224                 0.4B    ~1.5 GB   Apache-2.0     multilingual; load-tested light fallback
#  google/siglip2-large-patch16-256                0.9B    ~3.53 GB  Apache-2.0     multilingual
#  jinaai/jina-clip-v2                             0.9B    ~1.73 GB  CC-BY-NC-4.0   89 langs, multimodal; needs: uv add einops
#  jinaai/jina-embeddings-v5-omni-nano-retrieval   ~0.95B  ~1.9 GB   CC-BY-NC-4.0   2026 multimodal (verify it exists)
#  jinaai/jina-embeddings-v5-omni-small-retrieval  ~1.56B  ~3.12 GB  CC-BY-NC-4.0   2026 multimodal (verify it exists)
#  openai/clip-vit-large-patch14                   0.4B    ~1.71 GB  MIT            English only
#  apple/MobileCLIP2-S2                            ~99M    ~398 MB   Apple-AMLR     research-only; needs: uv add open_clip_torch
#  jinaai/jina-embeddings-v4                       4B      ~7.89 GB  Qwen-Research  legacy/heavy, GPU recommended
#
# Run `python -m app models` for the same list with full install notes.
#
# IF THE DEFAULT FAILS TO LOAD: the Qwen default is unverified in this build.
# Set MODEL_NAME=google/siglip2-base-patch16-224 (tested) and run sync again.
#
# NOTE: text-only models (Gemini Embedding, OpenAI text-embedding, BGE, E5)
# do NOT work here — they can't "look at" sticker images.

MODEL_NAME=Qwen/Qwen3-VL-Embedding-2B

# Custom model: MODEL_NAME also accepts a LOCAL FOLDER PATH (not only a HF id),
# e.g.  MODEL_NAME=/home/me/models/my-clip   (or  C:\models\my-clip  on Windows).
# It must be a CLIP-style model that embeds BOTH images and text.

# Advanced only: separate image encoder for a custom dual-model setup.
# Leave EMPTY unless you know you need it.
IMAGE_MODEL_NAME=

# Where to run the model: auto | cpu | cuda
#   auto = use GPU if available, else CPU (auto-falls back to CPU on out-of-memory)
# The 2B default needs ~8 GB VRAM. On a smaller/busy GPU set DEVICE=cpu
# (uses system RAM, slower but reliable).
DEVICE=auto


# ------------------------------------------------------------
# SEARCH & SYNC TUNING (defaults are fine)
# ------------------------------------------------------------

# How many stickers the bot returns per query.
TOP_K=10

# How many frames to sample from animated stickers / GIFs for embedding.
# More frames = slightly better matching but slower indexing and more disk.
FRAME_COUNT=5

# How many files to download from Telegram in parallel. Higher = faster,
# but too high may trigger Telegram rate limits. 4 is a safe value.
SCAN_CONCURRENCY=4

# Delay (milliseconds) between stickers when the bot sends results,
# to avoid hitting Telegram's send limits.
BOT_SEND_DELAY_MS=250


# ------------------------------------------------------------
# LOCAL PATHS (leave as-is unless you want a custom location)
# ------------------------------------------------------------
DATA_DIR=./data
SESSION_PATH=./data/sessions/user
DB_PATH=./data/app.sqlite


# ------------------------------------------------------------
# OPTIONAL / EXPERIMENTAL (leave off)
# ------------------------------------------------------------
ENABLE_CAPTIONS=false
CAPTION_PROVIDER=none
