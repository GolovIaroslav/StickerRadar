# ============================================================
# StickerRadar — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Telegram credentials ---
# Get TG_API_ID and TG_API_HASH from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram numeric user ID (get it from @userinfobot or @getidsbot)
OWNER_USER_ID=

# --- Local paths (defaults work fine, change only if needed) ---
DATA_DIR=./data
SESSION_PATH=./data/sessions/user
DB_PATH=./data/app.sqlite

# --- Embedding model ---
# Default: SigLIP2 base (Google 2025, multilingual, ~0.4 GB)
MODEL_NAME=google/siglip2-base-patch16-224

# Higher quality (2024, 89 languages, ~3.5 GB):
# MODEL_NAME=jinaai/jina-clip-v2     (also: uv add einops)
# Larger SigLIP2 (~1.5 GB):
# MODEL_NAME=google/siglip2-large-patch16-256

# Custom model: separate image encoder for a dual sentence-transformers setup
# (leave empty unless you know you need it)
IMAGE_MODEL_NAME=

# Run `python -m app models` for the full list and install instructions.

# --- Runtime tuning ---
TOP_K=10
FRAME_COUNT=5
SCAN_CONCURRENCY=4
BOT_SEND_DELAY_MS=250

# --- Optional features (leave as-is for MVP) ---
ENABLE_CAPTIONS=false
CAPTION_PROVIDER=none
